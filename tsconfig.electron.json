{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": false,
    "noEmit": false,
    "outDir": "./dist-electron",
    "rootDir": "./",
    "baseUrl": "./"
  },
  "include": ["main.ts", "preload.ts", "electron/**/*"],
  "exclude": ["node_modules", ".next", "out", "src", "public"]
}
